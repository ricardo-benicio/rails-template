# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Rails master key for credentials decryption
RAILS_MASTER_KEY=$(cat config/master.key)

# Docker Hub registry credentials
# Set these environment variables before running kamal deploy:
#   export KAMAL_REGISTRY_USERNAME=your-dockerhub-username
#   export KAMAL_REGISTRY_PASSWORD=your-dockerhub-access-token
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# PostgreSQL password for the db accessory
# Set this environment variable before running kamal deploy:
#   export POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# Database URL for the Rails app (connects to the PostgreSQL accessory)
DATABASE_URL="postgresql://rails_template:${POSTGRES_PASSWORD}@rails_template-db:5432/rails_template_production"

# Redis password (optional, for securing Redis accessory)
# export REDIS_PASSWORD=your-redis-password
# REDIS_PASSWORD=$REDIS_PASSWORD
