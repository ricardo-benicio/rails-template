<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body { font-family: sans-serif; color: #333; }
      .container { max-width: 600px; margin: 40px auto; padding: 24px; }
      .btn { display: inline-block; padding: 12px 24px; background: #1a1a1a; color: #fff; text-decoration: none; border-radius: 6px; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Welcome, <%= @user.first_name %>!</h1>
      <p>Your account is confirmed and ready to use.</p>
      <p><a href="<%= root_url %>" class="btn">Get started</a></p>
    </div>
  </body>
</html>
