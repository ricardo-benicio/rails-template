<% content_for(:title) { t("app.name") } %>

<div class="w-full max-w-4xl mx-auto text-center">
  <!-- Hero Section -->
  <div class="py-16">
    <h1 class="text-5xl font-bold text-gray-900 dark:text-white mb-6">
      <%= t("app.name") %>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
      <%= t("app.description") %>
    </p>

    <div class="flex justify-center gap-4">
      <% if user_signed_in? %>
        <%= link_to t("home.dashboard"), admin_root_path,
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" if current_user.admin? %>
        <%= link_to t("home.my_account"), edit_user_registration_path,
            class: "inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-700" %>
      <% else %>
        <%= link_to t("home.get_started"), new_user_registration_path,
            class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        <%= link_to t("home.sign_in"), new_user_session_path,
            class: "inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-700" %>
      <% end %>
    </div>
  </div>

  <!-- Features Section -->
  <div class="py-12 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
      <%= t("home.features.title") %>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="p-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900 rounded-lg flex items-center justify-center mb-4 mx-auto">
          <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
          <%= t("home.features.authentication.title") %>
        </h3>
        <p class="text-gray-600 dark:text-gray-300">
          <%= t("home.features.authentication.description") %>
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="p-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900 rounded-lg flex items-center justify-center mb-4 mx-auto">
          <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
          <%= t("home.features.api.title") %>
        </h3>
        <p class="text-gray-600 dark:text-gray-300">
          <%= t("home.features.api.description") %>
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="p-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900 rounded-lg flex items-center justify-center mb-4 mx-auto">
          <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
          <%= t("home.features.performance.title") %>
        </h3>
        <p class="text-gray-600 dark:text-gray-300">
          <%= t("home.features.performance.description") %>
        </p>
      </div>
    </div>
  </div>

  <!-- Tech Stack Section -->
  <div class="py-12 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
      <%= t("home.tech_stack.title") %>
    </h2>

    <div class="flex flex-wrap justify-center gap-4">
      <% %w[Rails Ruby PostgreSQL Hotwire Tailwind Devise Sidekiq Redis].each do |tech| %>
        <span class="px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm font-medium border border-gray-200 dark:border-gray-700">
          <%= tech %>
        </span>
      <% end %>
    </div>
  </div>

  <!-- Footer -->
  <footer class="py-8 border-t border-gray-200 dark:border-gray-700 text-center text-gray-500 dark:text-gray-400 text-sm">
    <p><%= t("home.footer.built_with") %></p>
    <p class="mt-2">
      Rails <%= Rails.version %> &middot; Ruby <%= RUBY_VERSION %>
    </p>
  </footer>
</div>
