# ============================================
# Rails Template - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# Rails
# ============================================
RAILS_ENV=development
RAILS_MAX_THREADS=5
SECRET_KEY_BASE=your_secret_key_base_here

# ============================================
# Database (Local Development)
# ============================================
# For local PostgreSQL:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_HOST=localhost

# For Supabase (overrides local settings):
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_PREPARED_STATEMENTS=false

# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Storage bucket name
SUPABASE_STORAGE_BUCKET=uploads

# ============================================
# Redis (for Sidekiq)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# JWT (for API authentication)
# ============================================
JWT_SECRET_KEY=your_jwt_secret_key_here

# ============================================
# AppSignal (Monitoring)
# ============================================
APPSIGNAL_PUSH_API_KEY=your_appsignal_key_here
APPSIGNAL_APP_NAME=rails-template
APPSIGNAL_APP_ENV=development

# ============================================
# Application
# ============================================
APP_HOST=localhost:3000
APP_PROTOCOL=http
